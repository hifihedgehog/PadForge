<ui:FluentWindow x:Class="PadForge.Views.ProfileSwitchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowBackdropType="Acrylic"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="Width"
        Height="45"
        WindowStartupLocation="Manual"
        Background="Transparent">

    <!--
        Win11 Hardware Confirmator (volume OSD) — pixel-measured.
        Uses system acrylic backdrop via FluentWindow + DWM corner rounding.
        Background: acrylic over #2C2D2D, Border: #121313 1px, Corner: 8px (DWM).
    -->
    <Grid x:Name="ContentPanel" Margin="16,0,16,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="StatusIcon"
                       Text="&#xE8F1;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="White"/>

            <TextBlock x:Name="StatusText"
                       FontSize="14"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       VerticalAlignment="Center"
                       Foreground="White"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
