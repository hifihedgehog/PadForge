<Window x:Class="PadForge.Views.CopyFromDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:strings="clr-namespace:PadForge.Resources.Strings"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding CopyFrom_Title, Source={x:Static strings:Strings.Instance}}"
        Height="360" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding CopyFrom_SelectDevice, Source={x:Static strings:Strings.Instance}}"
                   Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="DeviceList"
                 SelectionMode="Single"
                 MouseDoubleClick="DeviceList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding LayoutLabel}" FontSize="12"
                                       Margin="8,0,0,0" Opacity="0.7"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SlotLabel}" FontSize="12"
                                   Opacity="0.6"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{Binding Common_OK, Source={x:Static strings:Strings.Instance}}" MinWidth="80" Margin="0,0,8,0"
                    IsDefault="True" Click="OkButton_Click"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button Content="{Binding Common_Cancel, Source={x:Static strings:Strings.Instance}}" MinWidth="80"
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
