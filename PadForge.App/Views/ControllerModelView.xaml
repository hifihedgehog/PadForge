<UserControl x:Class="PadForge.Views.ControllerModelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Core.Wpf"
             xmlns:strings="clr-namespace:PadForge.Resources.Strings">

    <Grid>
        <helix:HelixViewport3D x:Name="ModelViewPort"
                               IsRotationEnabled="False"
                               IsPanEnabled="False"
                               IsMoveEnabled="False"
                               IsZoomEnabled="False"
                               ShowViewCube="False"
                               ZoomExtentsWhenLoaded="False"
                               Background="Transparent"
                               IsManipulationEnabled="False">

            <helix:SunLight />
            <helix:DirectionalHeadLight Brightness="0.35" />

            <ModelVisual3D x:Name="ModelVisual3D" />

            <helix:HelixViewport3D.Camera>
                <PerspectiveCamera FieldOfView="55"
                                   LookDirection="0,0.793,-0.609"
                                   Position="0,-172,132"
                                   UpDirection="0,0,1" />
            </helix:HelixViewport3D.Camera>
        </helix:HelixViewport3D>

        <!-- Reset View button -->
        <Button x:Name="ResetViewButton"
                Content="{Binding Pad_ResetView, Source={x:Static strings:Strings.Instance}}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Padding="8,4"
                Opacity="0.6"
                Click="ResetView_Click" />
    </Grid>
</UserControl>
