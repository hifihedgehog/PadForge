<UserControl x:Class="PadForge.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:strings="clr-namespace:PadForge.Resources.Strings">

    <ScrollViewer Padding="24,16">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static strings:Strings.Settings_Title}" Style="{StaticResource TitleTextBlockStyle}"/>
            </StackPanel>

            <!-- ═══ Language ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xF2B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_Language}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_LanguageDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="NativeName" Width="250"/>
                    <TextBlock Text="{x:Static strings:Strings.Settings_RestartRequired}"
                               FontSize="12" Opacity="0.5" Margin="0,8,0,0"
                               Visibility="{Binding LanguageChanged, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- ═══ Appearance ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_Appearance}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_AppearanceDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <TextBlock Text="{x:Static strings:Strings.Settings_Theme}" FontSize="13" Margin="0,0,0,6"/>
                    <ComboBox SelectedIndex="{Binding SelectedThemeIndex}" Width="200">
                        <ComboBoxItem Content="{x:Static strings:Strings.Settings_ThemeSystem}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.Settings_ThemeLight}"/>
                        <ComboBoxItem Content="{x:Static strings:Strings.Settings_ThemeDark}"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- ═══ Engine ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_InputEngine}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_InputEngineDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <CheckBox Content="{x:Static strings:Strings.Settings_AutoStart}"
                              IsChecked="{Binding AutoStartEngine}" Margin="0,0,0,8"/>
                    <CheckBox Content="{x:Static strings:Strings.Settings_BackgroundPolling}"
                              IsChecked="{Binding EnablePollingOnFocusLoss}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{x:Static strings:Strings.Settings_PollingInterval}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ui:NumberBox Value="{Binding PollingRateMs, Mode=TwoWay}"
                                      Minimum="1" Maximum="16"
                                      SpinButtonPlacementMode="Inline" Width="120"/>
                        <TextBlock Text="{x:Static strings:Strings.Common_Ms}" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Content="{x:Static strings:Strings.Settings_HideDevices}"
                              IsChecked="{Binding EnableInputHiding}"
                              ToolTip="{x:Static strings:Strings.Settings_HideDevicesTooltip}"/>
                </StackPanel>
            </Border>

            <!-- ═══ Window ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_Window}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_WindowDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <CheckBox Content="{x:Static strings:Strings.Settings_MinimizeToTray}"
                              IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,8"/>
                    <CheckBox Content="{x:Static strings:Strings.Settings_StartMinimized}"
                              IsChecked="{Binding StartMinimized}" Margin="0,0,0,8"/>
                    <CheckBox Content="{x:Static strings:Strings.Settings_StartAtLogin}"
                              IsChecked="{Binding StartAtLogin}"/>
                </StackPanel>
            </Border>

            <!-- ═══ HidHide ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_HidHide}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_HidHideDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsHidHideInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding HidHideStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HidHideVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{x:Static strings:Strings.Common_Install}"
                                    Command="{Binding InstallHidHideCommand}"
                                    Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{x:Static strings:Strings.Common_Uninstall}"
                                    Command="{Binding UninstallHidHideCommand}"
                                    Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Whitelist section (only when installed) -->
                    <StackPanel Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,16,0,0">
                        <TextBlock Text="{x:Static strings:Strings.Settings_WhitelistedApps}" FontWeight="SemiBold" FontSize="13"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_WhitelistDesc}"
                                   Style="{StaticResource CardDescription}" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding HidHideWhitelistPaths}"
                                 SelectedItem="{Binding SelectedWhitelistPath}"
                                 MaxHeight="140" MinHeight="32"
                                 Margin="0,0,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static strings:Strings.Settings_AddDots}" Command="{Binding AddWhitelistPathCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{x:Static strings:Strings.Common_Remove}" Command="{Binding RemoveWhitelistPathCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ ViGEmBus ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_ViGEmBus}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_ViGEmDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsViGEmInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ViGEmStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ViGEmVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{x:Static strings:Strings.Common_Install}"
                                    Command="{Binding InstallViGEmCommand}"
                                    Visibility="{Binding IsViGEmInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{x:Static strings:Strings.Common_Uninstall}"
                                    Command="{Binding UninstallViGEmCommand}"
                                    Visibility="{Binding IsViGEmInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ vJoy ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Path Data="M11.915 15H13V9.874A4.002 4.002 0 0 1 14 2a4 4 0 0 1 1 7.874V15h2a3 3 0 0 1 3 3v4H4v-4a3 3 0 0 1 3-3h.085A1.5 1.5 0 0 1 8.5 14h2a1.5 1.5 0 0 1 1.415 1z"
                              Fill="{DynamicResource SystemControlForegroundBaseHighBrush}"
                              Width="16" Height="16" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_VJoy}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_VJoyDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsVJoyInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding VJoyStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding VJoyVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{x:Static strings:Strings.Common_Install}"
                                    Command="{Binding InstallVJoyCommand}"
                                    Visibility="{Binding IsVJoyInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{x:Static strings:Strings.Common_Uninstall}"
                                    Command="{Binding UninstallVJoyCommand}"
                                    Visibility="{Binding IsVJoyInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Windows MIDI Services ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_MidiServices}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_MidiDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MidiServicesStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding MidiServicesVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{x:Static strings:Strings.Common_Install}"
                                    Command="{Binding InstallMidiServicesCommand}"
                                    Visibility="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMidiOsSupported}" Value="False">
                                                <Setter Property="ToolTip" Value="{x:Static strings:Strings.Settings_MidiOsRequired}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{x:Static strings:Strings.Common_Uninstall}"
                                    Command="{Binding UninstallMidiServicesCommand}"
                                    Visibility="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Settings File ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_SettingsFile}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_SettingsFileDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding SettingsFilePath}" FontSize="12"
                               FontFamily="Consolas" Opacity="0.7" TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{x:Static strings:Strings.Common_Save}" Command="{Binding SaveCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{x:Static strings:Strings.Settings_Reload}" Command="{Binding ReloadCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{x:Static strings:Strings.Settings_ResetToDefaults}" Command="{Binding ResetCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{x:Static strings:Strings.Settings_OpenFolder}" Command="{Binding OpenSettingsFolderCommand}"/>
                    </StackPanel>

                    <TextBlock Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{x:Static strings:Strings.Settings_UnsavedChanges}" Foreground="Orange"
                               FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ═══ Diagnostics ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{x:Static strings:Strings.Settings_Diagnostics}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static strings:Strings.Settings_DiagnosticsDesc}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{x:Static strings:Strings.Settings_AppVersion}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="{Binding ApplicationVersion}" FontSize="12"/>

                        <TextBlock Grid.Row="1" Text="{x:Static strings:Strings.Settings_DotNetRuntime}" FontSize="12"
                                   Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding RuntimeVersion}" FontSize="12" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2" Text="{x:Static strings:Strings.Settings_SdlVersion}" FontSize="12"
                                   Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SdlVersion}" FontSize="12" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
