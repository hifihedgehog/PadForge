<Window x:Class="PadForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:PadForge"
        xmlns:views="clr-namespace:PadForge.Views"
        xmlns:strings="clr-namespace:PadForge.Resources.Strings"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        Title="{Binding Title}"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App branding bar — hamburger on left, PadForge icon + name on right -->
        <Grid x:Name="AppBrandingBar" Grid.Row="0" Height="48" Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="PaneToggleBtn" Grid.Column="0" Click="PaneToggleBtn_Click"
                    Width="48" Height="48"
                    Background="Transparent"
                    BorderThickness="0" Padding="0"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
            </Button>
            <Border x:Name="AppBrandingBorder" Grid.Column="1" Padding="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resources/PadForge-icon.png" Width="20" Height="20"
                           RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                    <TextBlock Text="PadForge" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════
             Navigation View (left pane)
             ═══════════════════════════════════════════ -->
        <ui:NavigationView x:Name="NavView" Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleButtonVisible="False"
                           IsSettingsVisible="False"
                           AlwaysShowHeader="False"
                           CompactPaneLength="48"
                           SelectionChanged="NavView_SelectionChanged"
                           PaneTitle=""
                           OpenPaneLength="253">

            <ui:NavigationView.Resources>
                <Style TargetType="ui:NavigationViewItem">
                    <Setter Property="Height" Value="48"/>
                    <Setter Property="FontSize" Value="15"/>
                </Style>
            </ui:NavigationView.Resources>

            <!-- MenuItems built programmatically in code-behind (BuildNavigationItems) -->

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItemSeparator/>
                <ui:NavigationViewItem x:Name="NavSettings" Content="{Binding Settings_Title, Source={x:Static strings:Strings.Instance}}" Tag="Settings">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE713;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="NavAbout" Content="{Binding About_Title, Source={x:Static strings:Strings.Instance}}" Tag="About">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE946;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <!-- Content frame swapped by navigation -->
            <Grid Margin="0,12,0,12">
                <views:DashboardPage x:Name="DashboardPageView" Visibility="Visible"/>
                <views:PadPage x:Name="PadPageView" Visibility="Collapsed"/>
                <views:DevicesPage x:Name="DevicesPageView" Visibility="Collapsed"/>
                <views:SettingsPage x:Name="SettingsPageView" Visibility="Collapsed"/>
                <views:ProfilesPage x:Name="ProfilesPageView" Visibility="Collapsed"/>
                <views:AboutPage x:Name="AboutPageView" Visibility="Collapsed"/>
            </Grid>

        </ui:NavigationView>

        <!-- ═══════════════════════════════════════════
             Status Bar
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status text -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Devices count -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="{Binding ConnectedDeviceCount, Mode=OneWay}" Opacity="0.7"/>
                    <TextBlock Text="{Binding Main_DevicesSuffix, Source={x:Static strings:Strings.Instance}}" Opacity="0.7"/>
                </StackPanel>

                <!-- Polling frequency -->
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Opacity="0.7"
                           Text="{Binding PollingFrequency, StringFormat='{}{0:F0} Hz', Mode=OneWay}"/>

                <!-- Engine indicator -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding EngineStatusBrush}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding EngineStatusText}"
                               Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ═══════════════════════════════════════════
             Driver operation overlay (blocks UI during install/uninstall)
             ═══════════════════════════════════════════ -->
        <Grid x:Name="DriverOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Panel.ZIndex="1000">
            <Border Background="#80000000"/>
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="8"
                    Padding="32,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing IsActive="True"
                                     Width="40" Height="40"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,16"/>
                    <TextBlock x:Name="DriverOverlayText"
                               Text="{Binding Main_PleaseWait, Source={x:Static strings:Strings.Instance}}"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- ═══════════════════════════════════════════
             Shutdown overlay (shown while disposing controllers on close)
             ═══════════════════════════════════════════ -->
        <Grid x:Name="ShutdownOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Panel.ZIndex="1001">
            <Border Background="#CC000000"/>
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="8"
                    Padding="32,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="300">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing IsActive="True"
                                     Width="40" Height="40"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding Main_ShuttingDown, Source={x:Static strings:Strings.Instance}}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ShutdownOverlayText"
                               Text="{Binding Main_ReleasingControllers, Source={x:Static strings:Strings.Instance}}"
                               FontSize="13"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
