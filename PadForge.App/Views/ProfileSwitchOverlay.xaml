<Window x:Class="PadForge.Views.ProfileSwitchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="Height"
        Width="360"
        WindowStartupLocation="Manual">

    <!-- Outer margin reserves space for the drop shadow -->
    <Border Padding="29,29,29,42">
        <!-- Win11 hardware confirmator flyout -->
        <Border x:Name="FlyoutBorder"
                CornerRadius="8"
                Height="48"
                Background="#FF2C2C2C"
                BorderThickness="1">

            <Border.BorderBrush>
                <SolidColorBrush x:Name="FlyoutStroke" Color="#33000000"/>
            </Border.BorderBrush>

            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="12"
                                  Direction="270" Opacity="0.3" Color="Black"/>
            </Border.Effect>

            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <TextBlock x:Name="StatusIcon"
                           Grid.Column="0"
                           Text="&#xE8F1;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="16"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,12,0"
                           Foreground="White"/>

                <!-- Text -->
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           VerticalAlignment="Center"
                           Foreground="White"/>
            </Grid>
        </Border>
    </Border>
</Window>
