<UserControl x:Class="PadForge.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">

    <ScrollViewer Padding="24,16">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="About" Style="{StaticResource TitleTextBlockStyle}"/>
            </StackPanel>

            <!-- App identity -->
            <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PadForge" FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Controller Mapping Utility"
                               FontSize="14" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,4,0,12"/>

                    <TextBlock HorizontalAlignment="Center" Opacity="0.5" FontSize="12">
                        <Run Text="Modern fork of x360ce — rebuilt with SDL3, WPF, and .NET 10"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Description -->
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" LineHeight="22" Opacity="0.85">
                    PadForge maps any controller, keyboard, or mouse to virtual Xbox 360,
                    DualShock 4, custom DirectInput, or MIDI controllers via ViGEmBus, vJoy,
                    and Windows MIDI Services. It uses SDL3 for controller input, Windows
                    Raw Input for keyboard and mouse input, and provides a modern Fluent
                    Design interface for mapping, dead zone configuration, and force feedback
                    management.
                </TextBlock>
            </Border>

            <!-- Technologies -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Built With" Style="{StaticResource SubtitleTextBlockStyle}"/>
            </StackPanel>
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text=".NET 10" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Runtime and WPF framework" Opacity="0.7"/>

                    <TextBlock Grid.Row="1" Text="SDL3" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Controller input and enumeration"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="2" Text="Raw Input" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="Per-device keyboard and mouse input"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="3" Text="ViGEmBus" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="Virtual controller driver (Xbox 360, DualShock 4)"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="4" Text="vJoy" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="Virtual joystick driver for custom DirectInput output"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="5" Text="MIDI Services" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1"
                               Text="Virtual MIDI device output (Windows MIDI Services)"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="6" Text="HelixToolkit" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="6" Grid.Column="1"
                               Text="3D controller visualization"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="7" Text="ModernWpf" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="7" Grid.Column="1"
                               Text="Fluent Design theme for WPF"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="8" Text="MVVM Toolkit" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="8" Grid.Column="1"
                               Text="CommunityToolkit.Mvvm for data binding"
                               Opacity="0.7" Margin="0,6,0,0"/>
                </Grid>
            </Border>

            <!-- License -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="License" Style="{StaticResource SubtitleTextBlockStyle}"/>
            </StackPanel>
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12" LineHeight="18">
                    This software is licensed under CC BY-NC-SA 4.0
                    (Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International).
                    3D controller models adapted from Handheld Companion (CC BY-NC-SA 4.0).
                    2D controller assets from Gamepad-Asset-Pack by AL2009man (MIT).
                    Original codebase forked from x360ce (MIT).
                    SDL3 is licensed under the zlib License.
                    Windows MIDI Services is licensed under the MIT License.
                    ViGEmBus, vJoy, HelixToolkit, and ModernWpf are licensed under the MIT License.
                </TextBlock>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
