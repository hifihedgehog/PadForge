<UserControl x:Class="PadForge.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:strings="clr-namespace:PadForge.Resources.Strings">

    <ScrollViewer Padding="24,0">
        <StackPanel Margin="0,16,0,16">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding Settings_Title, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource TitleTextBlockStyle}"/>
            </StackPanel>

            <!-- ═══ Language ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xF2B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_Language, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_LanguageDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="NativeName" Width="250"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ═══ Appearance ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_Appearance, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_AppearanceDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Settings_Theme, Source={x:Static strings:Strings.Instance}}" FontSize="13" Margin="0,0,0,6"/>
                    <ComboBox SelectedIndex="{Binding SelectedThemeIndex}" Width="200"
                              HorizontalAlignment="Left">
                        <ComboBoxItem Content="{Binding Settings_ThemeSystem, Source={x:Static strings:Strings.Instance}}"/>
                        <ComboBoxItem Content="{Binding Settings_ThemeLight, Source={x:Static strings:Strings.Instance}}"/>
                        <ComboBoxItem Content="{Binding Settings_ThemeDark, Source={x:Static strings:Strings.Instance}}"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- ═══ Engine ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_InputEngine, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_InputEngineDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <CheckBox Content="{Binding Settings_AutoStart, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding AutoStartEngine}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding Settings_BackgroundPolling, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding EnablePollingOnFocusLoss}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding Settings_PollingInterval, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ui:NumberBox Value="{Binding PollingRateMs, Mode=TwoWay}"
                                      Minimum="1" Maximum="16"
                                      SpinButtonPlacementMode="Inline" Width="120"/>
                        <TextBlock Text="{Binding Common_Ms, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <CheckBox Content="{Binding Settings_HideDevices, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding EnableInputHiding}"
                              ToolTip="{Binding Settings_HideDevicesTooltip, Source={x:Static strings:Strings.Instance}}"/>
                </StackPanel>
            </Border>

            <!-- ═══ Window ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_Window, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_WindowDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <CheckBox Content="{Binding Settings_MinimizeToTray, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding Settings_StartMinimized, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding StartMinimized}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding Settings_StartAtLogin, Source={x:Static strings:Strings.Instance}}"
                              IsChecked="{Binding StartAtLogin}"/>
                </StackPanel>
            </Border>

            <!-- ═══ HidHide ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_HidHide, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_HidHideDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsHidHideInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding HidHideStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HidHideVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{Binding Common_Install, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding InstallHidHideCommand}"
                                    Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{Binding Common_Uninstall, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding UninstallHidHideCommand}"
                                    Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Whitelist section (only when installed) -->
                    <StackPanel Visibility="{Binding IsHidHideInstalled, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,16,0,0">
                        <TextBlock Text="{Binding Settings_WhitelistedApps, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" FontSize="13"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Settings_WhitelistDesc, Source={x:Static strings:Strings.Instance}}"
                                   Style="{StaticResource CardDescription}" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding HidHideWhitelistPaths}"
                                 SelectedItem="{Binding SelectedWhitelistPath}"
                                 MaxHeight="140" MinHeight="32"
                                 Margin="0,0,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{Binding Settings_AddDots, Source={x:Static strings:Strings.Instance}}" Command="{Binding AddWhitelistPathCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{Binding Common_Remove, Source={x:Static strings:Strings.Instance}}" Command="{Binding RemoveWhitelistPathCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ ViGEmBus ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_ViGEmBus, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_ViGEmDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsViGEmInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ViGEmStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ViGEmVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{Binding Common_Install, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding InstallViGEmCommand}"
                                    Visibility="{Binding IsViGEmInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{Binding Common_Uninstall, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding UninstallViGEmCommand}"
                                    Visibility="{Binding IsViGEmInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ vJoy ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Path Data="M11.915 15H13V9.874A4.002 4.002 0 0 1 14 2a4 4 0 0 1 1 7.874V15h2a3 3 0 0 1 3 3v4H4v-4a3 3 0 0 1 3-3h.085A1.5 1.5 0 0 1 8.5 14h2a1.5 1.5 0 0 1 1.415 1z"
                              Fill="{DynamicResource TextFillColorPrimaryBrush}"
                              Width="16" Height="16" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_VJoy, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_VJoyDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsVJoyInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding VJoyStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding VJoyVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{Binding Common_Install, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding InstallVJoyCommand}"
                                    Visibility="{Binding IsVJoyInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{Binding Common_Uninstall, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding UninstallVJoyCommand}"
                                    Visibility="{Binding IsVJoyInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Windows MIDI Services ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_MidiServices, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_MidiDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToColorConverter}}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MidiServicesStatusText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding MidiServicesVersion}" FontSize="12"
                                       Opacity="0.6" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{Binding Common_Install, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding InstallMidiServicesCommand}"
                                    Visibility="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMidiOsSupported}" Value="False">
                                                <Setter Property="ToolTip" Value="{Binding Settings_MidiOsRequired, Source={x:Static strings:Strings.Instance}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{Binding Common_Uninstall, Source={x:Static strings:Strings.Instance}}"
                                    Command="{Binding UninstallMidiServicesCommand}"
                                    Visibility="{Binding IsMidiServicesInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Settings File ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_SettingsFile, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_SettingsFileDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding SettingsFilePath}" FontSize="12"
                               FontFamily="Consolas" Opacity="0.7" TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding Common_Save, Source={x:Static strings:Strings.Instance}}" Command="{Binding SaveCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{Binding Settings_Reload, Source={x:Static strings:Strings.Instance}}" Command="{Binding ReloadCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{Binding Settings_ResetToDefaults, Source={x:Static strings:Strings.Instance}}" Command="{Binding ResetCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{Binding Settings_OpenFolder, Source={x:Static strings:Strings.Instance}}" Command="{Binding OpenSettingsFolderCommand}"/>
                    </StackPanel>

                    <TextBlock Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding Settings_UnsavedChanges, Source={x:Static strings:Strings.Instance}}" Foreground="Orange"
                               FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ═══ Diagnostics ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Settings_Diagnostics, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource CardTitle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Settings_DiagnosticsDesc, Source={x:Static strings:Strings.Instance}}"
                               Style="{StaticResource CardDescription}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Settings_AppVersion, Source={x:Static strings:Strings.Instance}}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="{Binding ApplicationVersion}" FontSize="12"/>

                        <TextBlock Grid.Row="1" Text="{Binding Settings_DotNetRuntime, Source={x:Static strings:Strings.Instance}}" FontSize="12"
                                   Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding RuntimeVersion}" FontSize="12" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2" Text="{Binding Settings_SdlVersion, Source={x:Static strings:Strings.Instance}}" FontSize="12"
                                   Opacity="0.6" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SdlVersion}" FontSize="12" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
