<Window x:Class="PadForge.Views.ConfigSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Select Game Config"
        Height="340" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Multiple community configs are available. Select one to apply:"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="ConfigListBox" Margin="0,0,0,12"
                 MouseDoubleClick="ConfigList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                            <TextBlock Text=" by " Opacity="0.6"/>
                            <TextBlock Text="{Binding Author}" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Notes}" FontSize="12" Opacity="0.7"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxHeight="36"/>
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value=""/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecommendedOutputType}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Output: "/><Run Text="{Binding RecommendedOutputType, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Apply" MinWidth="80" Margin="0,0,8,0"
                    IsDefault="True" Click="ApplyButton_Click"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button Content="Skip" MinWidth="80"
                    IsCancel="True" Click="SkipButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
