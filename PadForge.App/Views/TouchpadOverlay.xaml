<Window x:Class="PadForge.Views.TouchpadOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PadForge Touchpad"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="False"
        Width="500" Height="250"
        WindowStartupLocation="CenterScreen">

    <Canvas x:Name="RootCanvas" ClipToBounds="True">
        <!-- Left half: Finger 0 -->
        <Border x:Name="LeftZone"
                Canvas.Left="2" Canvas.Top="2"
                Width="246" Height="246"
                Background="#30FFFFFF"
                CornerRadius="8"
                BorderBrush="#60FFFFFF" BorderThickness="1">
            <TextBlock Text="Finger 1"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#80FFFFFF" FontSize="14"/>
        </Border>

        <!-- Right half: Finger 1 -->
        <Border x:Name="RightZone"
                Canvas.Left="252" Canvas.Top="2"
                Width="246" Height="246"
                Background="#30FFFFFF"
                CornerRadius="8"
                BorderBrush="#60FFFFFF" BorderThickness="1">
            <TextBlock Text="Finger 2"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#80FFFFFF" FontSize="14"/>
        </Border>

        <!-- Finger indicators -->
        <Ellipse x:Name="Finger0Dot" Width="20" Height="20"
                 Fill="#80FF6600" Visibility="Collapsed"
                 IsHitTestVisible="False"/>
        <Ellipse x:Name="Finger1Dot" Width="20" Height="20"
                 Fill="#800066FF" Visibility="Collapsed"
                 IsHitTestVisible="False"/>
    </Canvas>
</Window>
