<UserControl x:Class="PadForge.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:strings="clr-namespace:PadForge.Resources.Strings">

    <ScrollViewer Padding="24,16">
        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static strings:Strings.About_Title}" Style="{StaticResource TitleTextBlockStyle}"/>
            </StackPanel>

            <!-- App identity -->
            <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{x:Static strings:Strings.Common_PadForge}" FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Static strings:Strings.About_Subtitle}"
                               FontSize="14" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,4,0,12"/>

                    <TextBlock HorizontalAlignment="Center" Opacity="0.5" FontSize="12">
                        <Run Text="{x:Static strings:Strings.About_Tagline}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Description -->
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" LineHeight="22" Opacity="0.85"
                           Text="{x:Static strings:Strings.About_Description}"/>
            </Border>

            <!-- Technologies -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static strings:Strings.About_BuiltWith}" Style="{StaticResource SubtitleTextBlockStyle}"/>
            </StackPanel>
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static strings:Strings.About_DotNet10}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="{x:Static strings:Strings.About_DotNet10Desc}" Opacity="0.7"/>

                    <TextBlock Grid.Row="1" Text="{x:Static strings:Strings.About_SDL3}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Static strings:Strings.About_SDL3Desc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="2" Text="{x:Static strings:Strings.About_RawInput}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_RawInputDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="3" Text="{x:Static strings:Strings.About_ViGEmBus}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_ViGEmBusDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="4" Text="{x:Static strings:Strings.About_VJoy}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_VJoyDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="5" Text="{x:Static strings:Strings.About_MidiServices}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_MidiServicesDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="6" Text="{x:Static strings:Strings.About_HelixToolkit}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="6" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_HelixToolkitDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="7" Text="{x:Static strings:Strings.About_ModernWpf}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="7" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_ModernWpfDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="8" Text="{x:Static strings:Strings.About_MvvmToolkit}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="8" Grid.Column="1"
                               Text="{x:Static strings:Strings.About_MvvmToolkitDesc}"
                               Opacity="0.7" Margin="0,6,0,0"/>
                </Grid>
            </Border>

            <!-- License -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static strings:Strings.About_License}" Style="{StaticResource SubtitleTextBlockStyle}"/>
            </StackPanel>
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12" LineHeight="18"
                           Text="{x:Static strings:Strings.About_LicenseText}"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
