<UserControl x:Class="PadForge.Views.PadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PadForge.ViewModels"
             xmlns:controls="clr-namespace:PadForge.Controls"
             xmlns:views="clr-namespace:PadForge.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:strings="clr-namespace:PadForge.Resources.Strings"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PadViewModel}"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Style for dead zone slider groups -->
        <Style x:Key="DzLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="200"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style x:Key="DzSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="0.1"/>
        </Style>
        <Style x:Key="OffsetSlider" TargetType="Slider" BasedOn="{StaticResource DzSlider}">
            <Setter Property="Minimum" Value="-100"/>
        </Style>
        <Style x:Key="DzValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
        <Style x:Key="DzValueEdit" TargetType="TextBox">
            <Setter Property="Width" Value="48"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <Style x:Key="DzDigitEdit" TargetType="TextBox">
            <Setter Property="Width" Value="52"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="ToolTip" Value="Raw axis value"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style x:Key="DzPercent" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
        <Style x:Key="ResetButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Content" Value="&#xE72C;"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="Reset"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <Style x:Key="ResetAllButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Custom tab strip button (RadioButton styled as tab header) -->
        <Style x:Key="TabStripButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="PadTab"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="10,6" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-arrow separator between tab groups -->
        <Style x:Key="TabStripSeparator" TargetType="TextBlock">
            <Setter Property="Text" Value="&#xE76C;"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Device selector header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: vJoy config bar (visible only for vJoy slots) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Configuration tabs -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             ROW 0: Unified Tab Strip
             Combines navigation + device selector in one horizontal strip.
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="4,0" Margin="0,0,0,2"
                BorderBrush="{DynamicResource TextFillColorTertiaryBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- [Gamepad #  TypeIcon TypeName] — Controller tab -->
                <RadioButton x:Name="TabController" Tag="0" Style="{StaticResource TabStripButton}" Click="TabBtn_Click"
                             IsChecked="True"
                             AutomationProperties.AutomationId="TabController">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SlotNumber}" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Image Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{StaticResource GenericControllerIcon}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OutputType}" Value="Xbox360">
                                            <Setter Property="Source" Value="{StaticResource XboxControllerIcon}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OutputType}" Value="DualShock4">
                                            <Setter Property="Source" Value="{StaticResource DS4ControllerIcon}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OutputType}" Value="VJoy">
                                            <Setter Property="Source" Value="{StaticResource VJoyControllerIcon}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OutputType}" Value="Midi">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OutputType}" Value="KeyboardMouse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <!-- MIDI glyph icon (visible only when OutputType == Midi) -->
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OutputType}" Value="Midi">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Keyboard+Mouse glyph icon (visible only when OutputType == KeyboardMouse) -->
                        <TextBlock Text="&#xE961;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OutputType}" Value="KeyboardMouse">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding TypeInstanceLabel}" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <!-- [Macros] -->
                <RadioButton Tag="1" Style="{StaticResource TabStripButton}" Click="TabBtn_Click">
                    <TextBlock Text="{Binding Pad_Macros, Source={x:Static strings:Strings.Instance}}" FontSize="15"/>
                </RadioButton>

                <!-- | separator -->
                <TextBlock Style="{StaticResource TabStripSeparator}"/>

                <!-- [Device ▼] — inline ComboBox -->
                <ComboBox ItemsSource="{Binding MappedDevices}"
                          SelectedItem="{Binding SelectedMappedDevice, Mode=TwoWay}"
                          MinWidth="200" Margin="4,2" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF888888"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="Fill" Value="#FF4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- | separator -->
                <TextBlock Style="{StaticResource TabStripSeparator}"/>

                <!-- Config tabs -->
                <RadioButton Tag="2" Style="{StaticResource TabStripButton}" Click="TabBtn_Click"
                             AutomationProperties.AutomationId="MappingsTab">
                    <TextBlock Text="{Binding Pad_Mappings, Source={x:Static strings:Strings.Instance}}" FontSize="13"/>
                </RadioButton>
                <RadioButton x:Name="TabSticks" Tag="3" Style="{StaticResource TabStripButton}" Click="TabBtn_Click">
                    <TextBlock Text="{Binding Pad_Sticks, Source={x:Static strings:Strings.Instance}}" FontSize="13"/>
                </RadioButton>
                <RadioButton x:Name="TabTriggers" Tag="4" Style="{StaticResource TabStripButton}" Click="TabBtn_Click">
                    <TextBlock Text="{Binding Pad_Triggers, Source={x:Static strings:Strings.Instance}}" FontSize="13"/>
                </RadioButton>
                <RadioButton x:Name="TabForceFeedback" Tag="5" Style="{StaticResource TabStripButton}" Click="TabBtn_Click">
                    <TextBlock Text="{Binding Pad_ForceFeedback, Source={x:Static strings:Strings.Instance}}" FontSize="13"/>
                </RadioButton>
            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1: VJOY CONFIGURATION BAR
             (visible only when OutputType == VJoy)
             ══════════════════════════════════════ -->
        <Border x:Name="VJoyConfigBar" Grid.Row="1" Margin="4,4,4,0"
                Padding="10,6" CornerRadius="4"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource TextFillColorDisabledBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Preset selector -->
                <TextBlock Text="{Binding Pad_Preset, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                <ComboBox x:Name="VJoyPresetCombo" Width="130" VerticalAlignment="Center"
                          AutomationProperties.AutomationId="VJoyPresetCombo"
                          SelectionChanged="VJoyPresetCombo_SelectionChanged">
                    <ComboBoxItem Content="{Binding ControllerType_Xbox360, Source={x:Static strings:Strings.Instance}}"/>
                    <ComboBoxItem Content="{Binding ControllerType_DualShock4, Source={x:Static strings:Strings.Instance}}"/>
                    <ComboBoxItem Content="{Binding Pad_Custom, Source={x:Static strings:Strings.Instance}}"/>
                </ComboBox>

                <!-- Custom config spinners (visible when Custom preset) -->
                <StackPanel x:Name="VJoyCustomPanel" Orientation="Horizontal" Margin="16,0,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="{Binding Pad_VJoySticks, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBox x:Name="VJoyStickCountBox" Width="40" VerticalAlignment="Center"
                             AutomationProperties.AutomationId="VJoyStickCountBox"
                             TextAlignment="Center" Text="2"
                             LostFocus="VJoyCustomValue_Changed" KeyDown="VJoyCustomValue_KeyDown"/>

                    <TextBlock Text="{Binding Pad_VJoyTriggers, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBox x:Name="VJoyTriggerCountBox" Width="40" VerticalAlignment="Center"
                             AutomationProperties.AutomationId="VJoyTriggerCountBox"
                             TextAlignment="Center" Text="2"
                             LostFocus="VJoyCustomValue_Changed" KeyDown="VJoyCustomValue_KeyDown"/>

                    <TextBlock Text="{Binding Pad_VJoyPOVs, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBox x:Name="VJoyPovCountBox" Width="40" VerticalAlignment="Center"
                             AutomationProperties.AutomationId="VJoyPovCountBox"
                             TextAlignment="Center" Text="1"
                             LostFocus="VJoyCustomValue_Changed" KeyDown="VJoyCustomValue_KeyDown"/>

                    <TextBlock Text="{Binding Pad_VJoyButtons, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBox x:Name="VJoyButtonCountBox" Width="72" VerticalAlignment="Center"
                             AutomationProperties.AutomationId="VJoyButtonCountBox"
                             TextAlignment="Center" Text="11"
                             LostFocus="VJoyCustomValue_Changed" KeyDown="VJoyCustomValue_KeyDown"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 (alt): MIDI CONFIGURATION BAR
             (visible only when OutputType == Midi)
             ══════════════════════════════════════ -->
        <Border x:Name="MidiConfigBar" Grid.Row="1" Margin="4,4,4,0"
                Padding="10,6" CornerRadius="4"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource TextFillColorDisabledBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Pad_MidiChannel, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiChannelTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiChannelBox" Width="40" VerticalAlignment="Center"
                         TextAlignment="Center" Text="1"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>

                <TextBlock Text="{Binding Pad_MidiCCCount, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiCCCountTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiCcCountBox" Width="54" VerticalAlignment="Center"
                         TextAlignment="Center" Text="6"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>

                <TextBlock Text="{Binding Pad_MidiStartCC, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiStartCCTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiStartCcBox" Width="54" VerticalAlignment="Center"
                         TextAlignment="Center" Text="1"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>

                <TextBlock Text="{Binding Pad_MidiNoteCount, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiNoteCountTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiNoteCountBox" Width="54" VerticalAlignment="Center"
                         TextAlignment="Center" Text="11"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>

                <TextBlock Text="{Binding Pad_MidiStartNote, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiStartNoteTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiStartNoteBox" Width="54" VerticalAlignment="Center"
                         TextAlignment="Center" Text="60"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>

                <TextBlock Text="{Binding Pad_MidiVelocity, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="12,0,4,0" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           ToolTip="{Binding Pad_MidiVelocityTooltip, Source={x:Static strings:Strings.Instance}}"/>
                <TextBox x:Name="MidiVelocityBox" Width="54" VerticalAlignment="Center"
                         TextAlignment="Center" Text="127"
                         LostFocus="MidiConfig_Changed" KeyDown="MidiConfig_KeyDown"/>
            </StackPanel>
        </Border>

        <!-- Expose Mappings count for UI Automation tests (invisible but accessible) -->
        <TextBlock AutomationProperties.AutomationId="MappingsCountIndicator"
                   AutomationProperties.Name="{Binding Mappings.Count}"
                   Width="0" Height="0" Opacity="0"/>

        <!-- ═══════════════════════════════════════════
             ROW 2: Configuration TabControl
             Tabs: Controller | Mappings | Left Stick | Right Stick | Triggers | Force Feedback | Macros
             ═══════════════════════════════════════════ -->
        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedConfigTab, Mode=TwoWay}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                      ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ─── TAB 0: Controller (slot-level) ─── -->
            <TabItem>
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>      <!-- 3D viewport -->
                        <RowDefinition Height="Auto"/>   <!-- Motor bars -->
                        <RowDefinition Height="Auto"/>   <!-- Map All -->
                    </Grid.RowDefinitions>

                    <!-- ══════════════════════════════════════
                         CONTROLLER MODEL (2D / 3D)
                         ══════════════════════════════════════ -->
                    <Grid Grid.Row="0">
                        <views:ControllerModelView x:Name="ControllerModel3D" />
                        <views:ControllerModel2DView x:Name="ControllerModel2D" Visibility="Collapsed" />
                        <views:ControllerSchematicView x:Name="ControllerSchematic" Visibility="Collapsed" />
                        <views:MidiPreviewView x:Name="MidiPreview" Visibility="Collapsed" />
                        <views:KBMPreviewView x:Name="KBMPreview" Visibility="Collapsed" />

                        <!-- 2D/3D toggle button (top-left to avoid overlap with 3D Reset View) -->
                        <Button x:Name="ViewModeToggle" HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,8,0,0" Padding="6,4"
                                Click="ViewModeToggle_Click" ToolTip="{Binding Pad_SwitchTo2D, Source={x:Static strings:Strings.Instance}}">
                            <TextBlock x:Name="ViewModeIcon" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Text="&#xE8B9;"/>
                        </Button>
                    </Grid>

                    <!-- ══════════════════════════════════════
                         MOTOR ACTIVITY INDICATORS
                         ══════════════════════════════════════ -->
                    <Grid x:Name="MotorBarsGrid" Grid.Row="1" Width="500" Margin="0,4,0,4" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Cursor="Hand" Margin="0,0,12,0"
                                    MouseEnter="Motor_MouseEnter" MouseLeave="Motor_MouseLeave"
                                    MouseLeftButtonDown="LeftMotor_Click"
                                    ToolTip="{Binding Pad_TestLeftMotor, Source={x:Static strings:Strings.Instance}}"
                                    Background="Transparent">
                            <TextBlock Text="{Binding Pad_LeftMotor, Source={x:Static strings:Strings.Instance}}" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Border Height="24" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="3"
                                    BorderBrush="{DynamicResource TextFillColorDisabledBrush}" BorderThickness="1">
                                <Rectangle Fill="#FF2196F3" RadiusX="2" RadiusY="2"
                                           HorizontalAlignment="Left"
                                           Width="{Binding LeftMotorDisplay,
                                               Converter={StaticResource NormToTriggerHeightConverter},
                                               ConverterParameter=240}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Cursor="Hand" Margin="12,0,0,0"
                                    MouseEnter="Motor_MouseEnter" MouseLeave="Motor_MouseLeave"
                                    MouseLeftButtonDown="RightMotor_Click"
                                    ToolTip="{Binding Pad_TestRightMotor, Source={x:Static strings:Strings.Instance}}"
                                    Background="Transparent">
                            <TextBlock Text="{Binding Pad_RightMotor, Source={x:Static strings:Strings.Instance}}" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Border Height="24" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="3"
                                    BorderBrush="{DynamicResource TextFillColorDisabledBrush}" BorderThickness="1">
                                <Rectangle Fill="#FF2196F3" RadiusX="2" RadiusY="2"
                                           HorizontalAlignment="Left"
                                           Width="{Binding RightMotorDisplay,
                                               Converter={StaticResource NormToTriggerHeightConverter},
                                               ConverterParameter=240}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ══════════════════════════════════════
                         MAP ALL — Controller tab controls
                         ══════════════════════════════════════ -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
                        <Button Content="{Binding Pad_MapAll, Source={x:Static strings:Strings.Instance}}" Command="{Binding MapAllCommand}"
                                Padding="16,8" FontSize="14"
                                ToolTip="{Binding Pad_MapAllTooltip, Source={x:Static strings:Strings.Instance}}"/>
                        <Button Content="{Binding Common_Stop, Source={x:Static strings:Strings.Instance}}" Padding="12,6" FontSize="14"
                                Visibility="{Binding IsMapAllActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="MapAllStop_Click"/>
                        <TextBlock Text="{Binding MapAllPromptText}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="#FF2196F3"
                                   Visibility="{Binding MapAllPromptText, Converter={StaticResource NullToCollapsedConverter}}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB 1: Macros (slot-level) ─── -->
            <TabItem>
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Macro list -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="{Binding Common_Add, Source={x:Static strings:Strings.Instance}}" Command="{Binding AddMacroCommand}"
                                    Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="{Binding Common_Remove, Source={x:Static strings:Strings.Instance}}" Command="{Binding RemoveMacroCommand}"
                                    Padding="8,4"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Macros}"
                                 SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                                 DisplayMemberPath="Name"/>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="4" Margin="4,0"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- Macro editor (shows when a macro is selected) -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                                  Padding="8"
                                  DataContext="{Binding SelectedMacro}"
                                  Visibility="{Binding DataContext.HasSelectedMacro,
                                      RelativeSource={RelativeSource AncestorType=TabItem},
                                      Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <!-- Macro name -->
                            <TextBlock Text="{Binding Macro_Name, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <!-- Enabled -->
                            <CheckBox Content="{Binding Common_Enabled, Source={x:Static strings:Strings.Instance}}" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      Margin="0,0,0,12"/>

                            <!-- Trigger mode -->
                            <TextBlock Text="{Binding Macro_Trigger, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Macro_Fire, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox SelectedValue="{Binding TriggerMode, Mode=TwoWay}"
                                          SelectedValuePath="Tag" MinWidth="120">
                                    <ComboBoxItem Content="{Binding Macro_OnPress, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerMode.OnPress}"/>
                                    <ComboBoxItem Content="{Binding Macro_OnRelease, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerMode.OnRelease}"/>
                                    <ComboBoxItem Content="{Binding Macro_WhileHeld, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerMode.WhileHeld}"/>
                                    <ComboBoxItem Content="{Binding Macro_Always, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerMode.Always}"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Trigger combination (hidden when Always mode) -->
                            <StackPanel Visibility="{Binding IsNotAlwaysMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding Macro_Trigger, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Macro_Source, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ComboBox SelectedValue="{Binding TriggerSource, Mode=TwoWay}"
                                              SelectedValuePath="Tag" MinWidth="160">
                                        <ComboBoxItem Content="{Binding Macro_InputDevice, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerSource.InputDevice}"/>
                                        <ComboBoxItem Content="{Binding Macro_OutputController, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroTriggerSource.OutputController}"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Grid MinWidth="150" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding TriggerDisplayText}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsRecordingTrigger, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                        <TextBlock Text="{Binding RecordingLiveText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding IsRecordingTrigger, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <Button Content="{Binding RecordTriggerButtonText}"
                                            Command="{Binding RecordTriggerCommand}"
                                            Padding="8,4"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Macro_RecordHint, Source={x:Static strings:Strings.Instance}}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4"/>

                                <!-- Axis threshold (visible when an axis trigger was recorded) -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                            Visibility="{Binding UsesAxisTrigger, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Macro_Threshold, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <Slider Value="{Binding TriggerAxisThreshold, Mode=TwoWay}"
                                            Minimum="1" Maximum="100" Width="150"
                                            VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding TriggerAxisThreshold, Mode=OneWay}"/>
                                        <TextBlock Text="%"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Axis direction (visible when an axis trigger was recorded) -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                            Visibility="{Binding UsesAxisTrigger, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Macro_AxisDirection, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ComboBox SelectedIndex="{Binding TriggerAxisDirectionIndex, Mode=TwoWay}" MinWidth="120">
                                        <ComboBoxItem Content="{Binding Macro_AxisDirection_Any, Source={x:Static strings:Strings.Instance}}"/>
                                        <ComboBoxItem Content="{Binding Macro_AxisDirection_Positive, Source={x:Static strings:Strings.Instance}}"/>
                                        <ComboBoxItem Content="{Binding Macro_AxisDirection_Negative, Source={x:Static strings:Strings.Instance}}"/>
                                    </ComboBox>
                                </StackPanel>

                                <CheckBox Content="{Binding Macro_ConsumeTrigger, Source={x:Static strings:Strings.Instance}}"
                                          IsChecked="{Binding ConsumeTriggerButtons, Mode=TwoWay}"
                                          Margin="0,0,0,4"/>
                            </StackPanel>

                            <!-- Always mode note -->
                            <TextBlock Text="{Binding Macro_AlwaysDesc, Source={x:Static strings:Strings.Instance}}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding IsNotAlwaysMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>

                            <Separator Margin="0,4,0,12"/>

                            <!-- Action sequence -->
                            <TextBlock Text="{Binding Macro_ActionSequence, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="{Binding Macro_AddAction, Source={x:Static strings:Strings.Instance}}" Command="{Binding AddActionCommand}"
                                        Padding="8,4" Margin="0,0,4,0"/>
                                <Button Content="{Binding Common_Remove, Source={x:Static strings:Strings.Instance}}" Command="{Binding RemoveActionCommand}"
                                        Padding="8,4"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Actions}"
                                     SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayText"
                                     MinHeight="100" MaxHeight="200" Margin="0,0,0,4"/>

                            <!-- Action editor (shows when an action is selected) -->
                            <Border BorderBrush="{DynamicResource TextFillColorTertiaryBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,12"
                                    DataContext="{Binding SelectedAction}"
                                    Visibility="{Binding DataContext.SelectedAction,
                                        RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                        Converter={StaticResource NullToCollapsedConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Macro_EditAction, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                    <!-- Action type -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Macro_ActionType, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                   Width="80" Margin="0,0,8,0"/>
                                        <ComboBox SelectedValue="{Binding Type, Mode=TwoWay}"
                                                  SelectedValuePath="Tag" MinWidth="150">
                                            <ComboBoxItem Content="{Binding Macro_ButtonPress, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.ButtonPress}"/>
                                            <ComboBoxItem Content="{Binding Macro_ButtonRelease, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.ButtonRelease}"/>
                                            <ComboBoxItem Content="{Binding Macro_KeyPress, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.KeyPress}"/>
                                            <ComboBoxItem Content="{Binding Macro_KeyRelease, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.KeyRelease}"/>
                                            <ComboBoxItem Content="{Binding Macro_Delay, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.Delay}"/>
                                            <ComboBoxItem Content="{Binding Macro_SetAxis, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.AxisSet}"/>
                                            <ComboBoxItem Content="{Binding Macro_SystemVolume, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.SystemVolume}"/>
                                            <ComboBoxItem Content="{Binding Macro_AppVolume, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.AppVolume}"/>
                                            <ComboBoxItem Content="{Binding Macro_MouseMove, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.MouseMove}"/>
                                            <ComboBoxItem Content="{Binding Macro_MouseButtonPress, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.MouseButtonPress}"/>
                                            <ComboBoxItem Content="{Binding Macro_MouseButtonRelease, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.MouseButtonRelease}"/>
                                            <ComboBoxItem Content="{Binding Macro_MouseScroll, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroActionType.MouseScroll}"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Button flags — checkbox grid for ButtonPress / ButtonRelease -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsButtonType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Macro_Buttons, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ItemsControl ItemsSource="{Binding ButtonOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}"
                                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              MinWidth="70" Margin="0,0,8,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Key combo — for KeyPress / KeyRelease -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsKeyType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Macro_KeyCombo, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding KeyString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" Margin="0,0,0,4"
                                                 ToolTip="{Binding Macro_KeyComboTooltip, Source={x:Static strings:Strings.Instance}}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox ItemsSource="{x:Static vm:MacroAction.VirtualKeyValues}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding SelectedKeyToAdd, Mode=TwoWay}"
                                                      MinWidth="180" MaxDropDownHeight="300"
                                                      IsTextSearchEnabled="True"/>
                                            <Button Content="{Binding Common_Clear, Source={x:Static strings:Strings.Instance}}" Command="{Binding ClearKeyStringCommand}"
                                                    Padding="8,4" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Macro_KeyComboHint, Source={x:Static strings:Strings.Instance}}"
                                                   FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Duration — for ButtonPress / KeyPress / Delay -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                Visibility="{Binding IsDurationType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Macro_Duration, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                   Width="80" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding DurationMs, Mode=TwoWay}" Width="80"/>
                                        <TextBlock Text="{Binding Common_Ms, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>

                                    <!-- Axis target + value — for AxisSet -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                Visibility="{Binding IsAxisType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Macro_Axis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                   Width="80" Margin="0,0,8,0"/>
                                        <ComboBox SelectedValue="{Binding AxisTarget, Mode=TwoWay}"
                                                  SelectedValuePath="Tag" MinWidth="120">
                                            <ComboBoxItem Content="{Binding Common_None, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.None}"/>
                                            <ComboBoxItem Content="{Binding Macro_LeftStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickX}"/>
                                            <ComboBoxItem Content="{Binding Macro_LeftStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickY}"/>
                                            <ComboBoxItem Content="{Binding Macro_RightStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickX}"/>
                                            <ComboBoxItem Content="{Binding Macro_RightStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickY}"/>
                                            <ComboBoxItem Content="{Binding Macro_LeftTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftTrigger}"/>
                                            <ComboBoxItem Content="{Binding Macro_RightTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightTrigger}"/>
                                        </ComboBox>
                                        <TextBlock Text="{Binding Macro_AxisValue, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                   Margin="12,0,8,0"/>
                                        <TextBox Text="{Binding AxisValue, Mode=TwoWay}" Width="80"/>
                                    </StackPanel>

                                    <!-- Source axis — for SystemVolume -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsSystemVolumeType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <!-- Axis source selector -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_AxisFrom, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisSource, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_OutputController, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.OutputController}"/>
                                                <ComboBoxItem Content="{Binding Macro_InputDevice, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.InputDevice}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Output controller axis (existing) -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                                    Visibility="{Binding IsOutputAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding Macro_SourceAxis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisTarget, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_LeftStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftTrigger}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightTrigger}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Input device axis -->
                                        <StackPanel Visibility="{Binding IsDeviceAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Device, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="SysVolDevicePicker"
                                                          MinWidth="200"
                                                          DisplayMemberPath="ResolvedName"
                                                          SelectedValuePath="InstanceGuid"
                                                          SelectedValue="{Binding SourceDeviceGuid, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisPicker_DropDownOpened"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Axis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox MinWidth="180"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="InputIndex"
                                                          SelectedValue="{Binding SourceDeviceAxisIndex, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisIndexPicker_DropDownOpened"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_VolumeLimit, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <Slider Value="{Binding VolumeLimit, Mode=TwoWay}"
                                                    Minimum="1" Maximum="100" Width="150"
                                                    VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding VolumeLimit, Mode=OneWay}"/>
                                                <TextBlock Text="%"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox Content="{Binding Macro_InvertAxis, Source={x:Static strings:Strings.Instance}}"
                                                 IsChecked="{Binding InvertAxis, Mode=TwoWay}" Margin="0,0,0,4"/>
                                        <CheckBox Content="{Binding Macro_ShowVolumeOsd, Source={x:Static strings:Strings.Instance}}"
                                                 IsChecked="{Binding ShowVolumeOsd, Mode=TwoWay}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Macro_SysVolumeHint, Source={x:Static strings:Strings.Instance}}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Source axis + process name — for AppVolume -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsAppVolumeType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_Process, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox IsEditable="True"
                                                      Text="{Binding ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding AudioProcessNames}"
                                                      MinWidth="180" MaxDropDownHeight="200"
                                                      IsTextSearchEnabled="True"
                                                      ToolTip="{Binding Macro_ProcessTooltip, Source={x:Static strings:Strings.Instance}}"
                                                      DropDownOpened="AppVolumeProcessDropDown_Opened"/>
                                        </StackPanel>
                                        <!-- Axis source selector -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_AxisFrom, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisSource, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_OutputController, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.OutputController}"/>
                                                <ComboBoxItem Content="{Binding Macro_InputDevice, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.InputDevice}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Output controller axis -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                                    Visibility="{Binding IsOutputAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding Macro_SourceAxis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisTarget, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_LeftStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftTrigger}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightTrigger}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Input device axis -->
                                        <StackPanel Visibility="{Binding IsDeviceAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Device, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="AppVolDevicePicker"
                                                          MinWidth="200"
                                                          DisplayMemberPath="ResolvedName"
                                                          SelectedValuePath="InstanceGuid"
                                                          SelectedValue="{Binding SourceDeviceGuid, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisPicker_DropDownOpened"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Axis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox MinWidth="180"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="InputIndex"
                                                          SelectedValue="{Binding SourceDeviceAxisIndex, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisIndexPicker_DropDownOpened"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_VolumeLimit, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <Slider Value="{Binding VolumeLimit, Mode=TwoWay}"
                                                    Minimum="1" Maximum="100" Width="150"
                                                    VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding VolumeLimit, Mode=OneWay}"/>
                                                <TextBlock Text="%"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox Content="{Binding Macro_InvertAxis, Source={x:Static strings:Strings.Instance}}"
                                                 IsChecked="{Binding InvertAxis, Mode=TwoWay}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Macro_AppVolumeHint, Source={x:Static strings:Strings.Instance}}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Source axis + sensitivity — for MouseMove / MouseScroll -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsMouseMoveType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <!-- Axis source selector -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_AxisFrom, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisSource, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_OutputController, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.OutputController}"/>
                                                <ComboBoxItem Content="{Binding Macro_InputDevice, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisSource.InputDevice}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Output controller axis -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                                    Visibility="{Binding IsOutputAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding Macro_SourceAxis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding AxisTarget, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="150">
                                                <ComboBoxItem Content="{Binding Macro_LeftStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickX, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickX}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightStickY, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightStickY}"/>
                                                <ComboBoxItem Content="{Binding Macro_LeftTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.LeftTrigger}"/>
                                                <ComboBoxItem Content="{Binding Macro_RightTrigger, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroAxisTarget.RightTrigger}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <!-- Input device axis -->
                                        <StackPanel Visibility="{Binding IsDeviceAxisSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Device, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="MouseDevicePicker"
                                                          MinWidth="200"
                                                          DisplayMemberPath="ResolvedName"
                                                          SelectedValuePath="InstanceGuid"
                                                          SelectedValue="{Binding SourceDeviceGuid, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisPicker_DropDownOpened"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Macro_Axis, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                           Width="80" Margin="0,0,8,0"/>
                                                <ComboBox MinWidth="180"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="InputIndex"
                                                          SelectedValue="{Binding SourceDeviceAxisIndex, Mode=TwoWay}"
                                                          DropDownOpened="DeviceAxisIndexPicker_DropDownOpened"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_Sensitivity, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <Slider Value="{Binding MouseSensitivity, Mode=TwoWay}"
                                                    Minimum="1" Maximum="100" Width="180"
                                                    TickPlacement="None" IsSnapToTickEnabled="False"
                                                    VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding MouseSensitivity, Mode=TwoWay, StringFormat=F0, UpdateSourceTrigger=LostFocus}"
                                                     Width="50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <CheckBox Content="{Binding Macro_InvertAxis, Source={x:Static strings:Strings.Instance}}"
                                                 IsChecked="{Binding InvertAxis, Mode=TwoWay}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Macro_MouseMoveHint, Source={x:Static strings:Strings.Instance}}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Mouse button — for MouseButtonPress / MouseButtonRelease -->
                                    <StackPanel Margin="0,0,0,6"
                                                Visibility="{Binding IsMouseButtonType, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Macro_Buttons, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                                       Width="80" Margin="0,0,8,0"/>
                                            <ComboBox SelectedValue="{Binding MouseButton, Mode=TwoWay}"
                                                      SelectedValuePath="Tag" MinWidth="120">
                                                <ComboBoxItem Content="{Binding Macro_MouseLeft, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroMouseButton.Left}"/>
                                                <ComboBoxItem Content="{Binding Macro_MouseRight, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroMouseButton.Right}"/>
                                                <ComboBoxItem Content="{Binding Macro_MouseMiddle, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroMouseButton.Middle}"/>
                                                <ComboBoxItem Content="{Binding Macro_MouseX1, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroMouseButton.X1}"/>
                                                <ComboBoxItem Content="{Binding Macro_MouseX2, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroMouseButton.X2}"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Repeat settings -->
                            <TextBlock Text="{Binding Macro_Repeat, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Macro_RepeatMode, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox SelectedValue="{Binding RepeatMode, Mode=TwoWay}"
                                          SelectedValuePath="Tag" MinWidth="120">
                                    <ComboBoxItem Content="{Binding Macro_Once, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroRepeatMode.Once}"/>
                                    <ComboBoxItem Content="{Binding Macro_FixedCount, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroRepeatMode.FixedCount}"/>
                                    <ComboBoxItem Content="{Binding Macro_UntilRelease, Source={x:Static strings:Strings.Instance}}" Tag="{x:Static vm:MacroRepeatMode.UntilRelease}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Macro_Count, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                           Margin="0,0,8,0" Width="50"/>
                                <TextBox Text="{Binding RepeatCount, Mode=TwoWay}"
                                         Width="60"/>
                                <TextBlock Text="{Binding Macro_DelayMs, Source={x:Static strings:Strings.Instance}}" VerticalAlignment="Center"
                                           Margin="12,0,8,0"/>
                                <TextBox Text="{Binding RepeatDelayMs, Mode=TwoWay}"
                                         Width="60"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ─── TAB 2: Mappings (device-specific) ─── -->
            <TabItem>
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{Binding Pad_ClearAll, Source={x:Static strings:Strings.Instance}}" Command="{Binding ClearMappingsCommand}"
                                Padding="8,4" Margin="0,0,8,0"/>
                        <Button Content="{Binding Common_Copy, Source={x:Static strings:Strings.Instance}}" Command="{Binding CopySettingsCommand}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{Binding Pad_CopyTooltip, Source={x:Static strings:Strings.Instance}}"/>
                        <Button Content="{Binding Common_Paste, Source={x:Static strings:Strings.Instance}}" Command="{Binding PasteSettingsCommand}"
                                Padding="8,4" Margin="0,0,4,0"
                                ToolTip="{Binding Pad_PasteTooltip, Source={x:Static strings:Strings.Instance}}"/>
                        <Button Content="{Binding Pad_CopyFrom, Source={x:Static strings:Strings.Instance}}" Command="{Binding CopyFromCommand}"
                                Padding="8,4" Margin="0,0,8,0"
                                ToolTip="{Binding Pad_CopyFromTooltip, Source={x:Static strings:Strings.Instance}}"/>
                        <Button Content="{Binding Pad_MapAll, Source={x:Static strings:Strings.Instance}}" Command="{Binding MapAllCommand}"
                                Padding="8,4" Margin="0,0,8,0"
                                ToolTip="{Binding Pad_MapAllOneByOne, Source={x:Static strings:Strings.Instance}}"/>
                        <TextBlock Text="{Binding Pad_MappingHint, Source={x:Static strings:Strings.Instance}}"
                                   VerticalAlignment="Center" FontStyle="Italic"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Mapping DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Mappings}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="True"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="RecordFlash">
                                                <Storyboard>
                                                    <ColorAnimation
                                                        Storyboard.TargetProperty="(DataGridRow.Background).(SolidColorBrush.Color)"
                                                        From="#002196F3" To="#602196F3"
                                                        Duration="0:0:0.4" AutoReverse="True"
                                                        RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="RecordFlash"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Pad_HeaderOutput, Source={x:Static strings:Strings.Instance}}"
                                                Binding="{Binding TargetLabel}"
                                                Width="195"/>
                            <DataGridTemplateColumn Header="{Binding Pad_HeaderSource, Source={x:Static strings:Strings.Instance}}"
                                                Width="215">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding AvailableInputs}"
                                                  SelectedItem="{Binding SelectedInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="DisplayName"
                                                  Margin="0" Padding="4,2"
                                                  HorizontalAlignment="Stretch"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{Binding Pad_HeaderValue, Source={x:Static strings:Strings.Instance}}"
                                                Binding="{Binding CurrentValueText, Mode=OneWay}"
                                                Width="60"/>
                            <!-- Record button -->
                            <DataGridTemplateColumn Header="" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding RecordButtonText}"
                                                Command="{Binding ToggleRecordCommand}"
                                                IsEnabled="{Binding IsRecordable}"
                                                Padding="6,2" Margin="2"
                                                MinWidth="85" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Clear button -->
                            <DataGridTemplateColumn Header="" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Common_Clear, Source={x:Static strings:Strings.Instance}}"
                                                Command="{Binding ClearCommand}"
                                                Padding="6,2" Margin="2"
                                                MinWidth="85" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Invert / Half-axis options -->
                            <DataGridTemplateColumn Header="{Binding Pad_HeaderOptions, Source={x:Static strings:Strings.Instance}}" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox Content="{Binding Pad_Invert, Source={x:Static strings:Strings.Instance}}" IsChecked="{Binding IsInverted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <CheckBox Content="{Binding Pad_Half, Source={x:Static strings:Strings.Instance}}" IsChecked="{Binding IsHalfAxis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Dead Zone (per-mapping axis activation threshold) -->
                            <DataGridTemplateColumn Header="{Binding Pad_HeaderDeadZone, Source={x:Static strings:Strings.Instance}}" Width="230">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDeadZoneApplicable}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Opacity" Value="0.35"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Slider Style="{StaticResource DzSlider}" Width="120"
                                                    Value="{Binding MappingDeadZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    TickFrequency="1"/>
                                            <TextBox Text="{Binding MappingDeadZone, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource DzValueEdit}"/>
                                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                            <Button Command="{Binding ResetDeadZoneCommand}" Style="{StaticResource ResetButton}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ─── TAB 3: Sticks (dynamic) ─── -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <ItemsControl ItemsSource="{Binding StickConfigs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:StickConfigItem}">
                                <StackPanel Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Command="{Binding ResetAllCommand}" Style="{StaticResource ResetAllButton}"
                                                Content="{Binding Pad_ResetAll, Source={x:Static strings:Strings.Instance}}" Margin="12,0,0,0"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Sliders (left) -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <!-- Center Offset Calibration -->
                                            <Button Margin="0,0,0,8"
                                                    Click="CalibrateCenter_Click"
                                                    Padding="8,4" HorizontalAlignment="Left">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Content" Value="{Binding Pad_CalibrateCenter, Source={x:Static strings:Strings.Instance}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCalibrating}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Content" Value="{Binding Pad_Sampling, Source={x:Static strings:Strings.Instance}}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_CenterOffsetX, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding CenterOffsetX, Mode=TwoWay}"
                                                        Style="{StaticResource OffsetSlider}"/>
                                                <TextBox Text="{Binding CenterOffsetX, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding CenterOffsetXDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetCenterOffsetXCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetCenterOffsetX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_CenterOffsetY, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding CenterOffsetY, Mode=TwoWay}"
                                                        Style="{StaticResource OffsetSlider}"/>
                                                <TextBox Text="{Binding CenterOffsetY, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding CenterOffsetYDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetCenterOffsetYCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetCenterOffsetY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_DeadZoneShape, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <ComboBox AutomationProperties.AutomationId="DeadZoneShapeCombo"
                                                          SelectedIndex="{Binding DeadZoneShapeIndex, Mode=TwoWay}"
                                                          Width="200" VerticalAlignment="Center">
                                                    <ComboBoxItem Content="{Binding Pad_DZScaledRadial, Source={x:Static strings:Strings.Instance}}"/>
                                                    <ComboBoxItem Content="{Binding Pad_DZRadial, Source={x:Static strings:Strings.Instance}}"/>
                                                    <ComboBoxItem Content="{Binding Pad_DZAxial, Source={x:Static strings:Strings.Instance}}"/>
                                                    <ComboBoxItem Content="{Binding Pad_DZHybrid, Source={x:Static strings:Strings.Instance}}"/>
                                                    <ComboBoxItem Content="{Binding Pad_DZSlopedScaledAxial, Source={x:Static strings:Strings.Instance}}"/>
                                                    <ComboBoxItem Content="{Binding Pad_DZSlopedAxial, Source={x:Static strings:Strings.Instance}}"/>
                                                </ComboBox>
                                                <Button Command="{Binding ResetDeadZoneShapeCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetDeadZoneShape, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_DeadZoneX, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding DeadZoneX, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding DeadZoneX, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding DeadZoneXDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetDeadZoneXCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetDeadZoneX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_DeadZoneY, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding DeadZoneY, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding DeadZoneY, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding DeadZoneYDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetDeadZoneYCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetDeadZoneY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_AntiDeadZoneX, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding AntiDeadZoneX, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding AntiDeadZoneX, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding AntiDeadZoneXDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetAntiDeadZoneXCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAntiDeadZoneX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_AntiDeadZoneY, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding AntiDeadZoneY, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding AntiDeadZoneY, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding AntiDeadZoneYDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetAntiDeadZoneYCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAntiDeadZoneY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_Linear, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding Linear, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding Linear, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <Button Command="{Binding ResetLinearCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetLinear, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Pad_SensitivityCurves, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,4,0,4"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding Pad_SensitivityCurveHint, Source={x:Static strings:Strings.Instance}}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_SensitivityX, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <ComboBox AutomationProperties.AutomationId="SensitivityXCombo"
                                                          Width="120"
                                                          ItemsSource="{x:Static vm:StickConfigItem.CurvePresetNames}"
                                                          SelectedItem="{Binding PresetNameX, Mode=OneWay}"
                                                          SelectionChanged="StickPresetX_SelectionChanged"
                                                          Tag="{Binding}"/>
                                                <Button Command="{Binding ResetSensitivityXCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetSensitivityX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_SensitivityY, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <ComboBox Width="120"
                                                          ItemsSource="{x:Static vm:StickConfigItem.CurvePresetNames}"
                                                          SelectedItem="{Binding PresetNameY, Mode=OneWay}"
                                                          SelectionChanged="StickPresetY_SelectionChanged"
                                                          Tag="{Binding}"/>
                                                <Button Command="{Binding ResetSensitivityYCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetSensitivityY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_MinRangeXLeft, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding MaxRangeXNeg, Mode=TwoWay}"
                                                        Minimum="1" Maximum="100"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding MaxRangeXNeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding MaxRangeXNegDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetMaxRangeXNegCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetMinRangeX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_MaxRangeXRight, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding MaxRangeX, Mode=TwoWay}"
                                                        Minimum="1" Maximum="100"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding MaxRangeX, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding MaxRangeXDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetMaxRangeXCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetMaxRangeX, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_MinRangeYDown, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding MaxRangeY, Mode=TwoWay}"
                                                        Minimum="1" Maximum="100"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding MaxRangeY, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding MaxRangeYDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetMaxRangeYCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetMinRangeY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_MaxRangeYUp, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding MaxRangeYNeg, Mode=TwoWay}"
                                                        Minimum="1" Maximum="100"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding MaxRangeYNeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding MaxRangeYNegDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetMaxRangeYNegCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetMaxRangeY, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Live preview (right) -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" MinWidth="216">
                                            <Border BorderBrush="#FF3F3F46" BorderThickness="2" CornerRadius="2"
                                                    Padding="4" Width="212" Height="212"
                                                    ClipToBounds="True">
                                                <Grid Width="200" Height="200">
                                                    <Ellipse Width="200" Height="200"
                                                             Fill="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                    <!-- Grid lines (Grid layer, behind Canvas) -->
                                                    <Line X1="50" Y1="0" X2="50" Y2="200" Stroke="#40FFFFFF" StrokeDashArray="2 4" StrokeThickness="0.5"/>
                                                    <Line X1="150" Y1="0" X2="150" Y2="200" Stroke="#40FFFFFF" StrokeDashArray="2 4" StrokeThickness="0.5"/>
                                                    <Line X1="0" Y1="50" X2="200" Y2="50" Stroke="#40FFFFFF" StrokeDashArray="2 4" StrokeThickness="0.5"/>
                                                    <Line X1="0" Y1="150" X2="200" Y2="150" Stroke="#40FFFFFF" StrokeDashArray="2 4" StrokeThickness="0.5"/>
                                                    <Line X1="100" Y1="0" X2="100" Y2="200" Stroke="#60FFFFFF" StrokeThickness="0.75"/>
                                                    <Line X1="0" Y1="100" X2="200" Y2="100" Stroke="#60FFFFFF" StrokeThickness="0.75"/>
                                                    <Canvas>
                                                        <Ellipse Width="196" Height="196" Canvas.Left="2" Canvas.Top="2"
                                                                 Stroke="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                 StrokeThickness="1.5" Fill="Transparent"/>
                                                        <Ellipse Width="98" Height="98" Canvas.Left="51" Canvas.Top="51"
                                                                 Stroke="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                                 StrokeDashArray="4 2" StrokeThickness="0.5" Fill="Transparent"/>
                                                        <!-- Dead zone overlay: Cross for Axial, Ellipse for Radial, Rectangle for Sloped -->

                                                        <!-- Axial: cross arms (yellow) — movement occurs but snapped to axis -->
                                                        <Path Fill="#20FFC107" Stroke="#50FFC107" StrokeThickness="1"
                                                              Visibility="{Binding IsAxialShape, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Path.Data>
                                                                <MultiBinding Converter="{StaticResource CrossGeometryConverter}">
                                                                    <Binding Path="DeadZoneX"/>
                                                                    <Binding Path="DeadZoneY"/>
                                                                </MultiBinding>
                                                            </Path.Data>
                                                        </Path>
                                                        <!-- Axial: center rectangle (red) — fully dead, no output -->
                                                        <Rectangle Fill="#18FF5722" Stroke="#60FF5722" StrokeThickness="1"
                                                                   Visibility="{Binding IsAxialShape, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Rectangle.Width>
                                                                <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Rectangle.Width>
                                                            <Rectangle.Height>
                                                                <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Rectangle.Height>
                                                            <Rectangle.RenderTransform>
                                                                <TranslateTransform>
                                                                    <TranslateTransform.X>
                                                                        <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.X>
                                                                    <TranslateTransform.Y>
                                                                        <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.Y>
                                                                </TranslateTransform>
                                                            </Rectangle.RenderTransform>
                                                            <Canvas.Left>100</Canvas.Left>
                                                            <Canvas.Top>100</Canvas.Top>
                                                        </Rectangle>

                                                        <!-- Radial: ellipse/circle -->
                                                        <Ellipse Fill="#18FF5722" Stroke="#60FF5722" StrokeThickness="1"
                                                                 Visibility="{Binding IsRadialShape, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Ellipse.Width>
                                                                <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Ellipse.Width>
                                                            <Ellipse.Height>
                                                                <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Ellipse.Height>
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform>
                                                                    <TranslateTransform.X>
                                                                        <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.X>
                                                                    <TranslateTransform.Y>
                                                                        <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.Y>
                                                                </TranslateTransform>
                                                            </Ellipse.RenderTransform>
                                                            <Canvas.Left>100</Canvas.Left>
                                                            <Canvas.Top>100</Canvas.Top>
                                                        </Ellipse>

                                                        <!-- Sloped / Hybrid: 4 triangular wedges (yellow) — axis-snapped regions -->
                                                        <Path Fill="#20FFC107" Stroke="#50FFC107" StrokeThickness="1"
                                                              Visibility="{Binding HasSlopedWedges, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Path.Data>
                                                                <MultiBinding Converter="{StaticResource SlopedWedgeGeometryConverter}">
                                                                    <Binding Path="DeadZoneX"/>
                                                                    <Binding Path="DeadZoneY"/>
                                                                </MultiBinding>
                                                            </Path.Data>
                                                        </Path>

                                                        <!-- Hybrid: circle (red) — fully dead center from radial stage -->
                                                        <Ellipse Fill="#18FF5722" Stroke="#60FF5722" StrokeThickness="1"
                                                                 Visibility="{Binding IsHybridShape, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Ellipse.Width>
                                                                <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Ellipse.Width>
                                                            <Ellipse.Height>
                                                                <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="200"/>
                                                            </Ellipse.Height>
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform>
                                                                    <TranslateTransform.X>
                                                                        <Binding Path="DeadZoneX" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.X>
                                                                    <TranslateTransform.Y>
                                                                        <Binding Path="DeadZoneY" Converter="{StaticResource PercentToSizeConverter}" ConverterParameter="-100"/>
                                                                    </TranslateTransform.Y>
                                                                </TranslateTransform>
                                                            </Ellipse.RenderTransform>
                                                            <Canvas.Left>100</Canvas.Left>
                                                            <Canvas.Top>100</Canvas.Top>
                                                        </Ellipse>
                                                        <!-- Stick position dot -->
                                                        <Ellipse Width="11" Height="11" Fill="#FF2196F3"
                                                                 Stroke="#FF1976D2" StrokeThickness="1"
                                                                 Canvas.Left="{Binding LiveX, Converter={StaticResource NormToCanvasConverter}, ConverterParameter='200,11'}"
                                                                 Canvas.Top="{Binding LiveY, Converter={StaticResource NormToCanvasConverter}, ConverterParameter='200,11'}"/>
                                                    </Canvas>
                                                </Grid>
                                            </Border>
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                                                       Text="{Binding RawDisplay, Mode=OneWay}"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                            <!-- Per-axis sensitivity curve editors -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <!-- X axis curve editor -->
                                                <StackPanel Margin="0,0,4,0">
                                                    <TextBlock Text="{Binding Pad_XAxis, Source={x:Static strings:Strings.Instance}}" HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="10" Margin="0,0,0,2"/>
                                                    <controls:CurveEditor
                                                        CurveString="{Binding SensitivityCurveX, Mode=TwoWay}"
                                                        DeadZone="{Binding DeadZoneX}"
                                                        MaxRange="{Binding MaxRangeX}"
                                                        MaxRangeNeg="{Binding MaxRangeXNeg}"
                                                        LiveInput="{Binding LiveInputX}"
                                                        IsSigned="True" ChartSize="96"/>
                                                </StackPanel>
                                                <!-- Y axis curve editor -->
                                                <StackPanel Margin="4,0,0,0">
                                                    <TextBlock Text="{Binding Pad_YAxis, Source={x:Static strings:Strings.Instance}}" HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="10" Margin="0,0,0,2"/>
                                                    <controls:CurveEditor
                                                        CurveString="{Binding SensitivityCurveY, Mode=TwoWay}"
                                                        DeadZone="{Binding DeadZoneY}"
                                                        MaxRange="{Binding MaxRangeYNeg}"
                                                        MaxRangeNeg="{Binding MaxRangeY}"
                                                        LiveInput="{Binding LiveInputY}"
                                                        IsSigned="True" ChartSize="96"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Margin="0,8,0,12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ─── TAB 4: Triggers (dynamic) ─── -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <ItemsControl ItemsSource="{Binding TriggerConfigs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TriggerConfigItem}">
                                <StackPanel Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Command="{Binding ResetAllCommand}" Style="{StaticResource ResetAllButton}"
                                                Content="{Binding Pad_ResetAll, Source={x:Static strings:Strings.Instance}}" Margin="12,0,0,0"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: sliders and live bar -->
                                        <StackPanel Grid.Column="0">
                                            <!-- Range (dual-thumb: dead zone floor — max range ceiling) -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_Range, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <controls:RangeSlider
                                                    LowerValue="{Binding DeadZone, Mode=TwoWay}"
                                                    UpperValue="{Binding MaxRange, Mode=TwoWay}"
                                                    Minimum="0" Maximum="100"
                                                    Width="200" VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding DeadZone, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="—" VerticalAlignment="Center" Margin="2,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBox Text="{Binding MaxRange, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding DeadZoneDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <TextBlock Text="—" VerticalAlignment="Center" Margin="2,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBox Text="{Binding MaxRangeDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetRangeCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetRange, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_AntiDeadZone, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <Slider Value="{Binding AntiDeadZone, Mode=TwoWay}"
                                                        Style="{StaticResource DzSlider}"/>
                                                <TextBox Text="{Binding AntiDeadZone, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzValueEdit}"/>
                                                <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                                                <TextBox Text="{Binding AntiDeadZoneDigit, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DzDigitEdit}"/>
                                                <Button Command="{Binding ResetAntiDeadZoneCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAntiDeadZone, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Pad_SensitivityCurve, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,4,0,4"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding Pad_SensitivityCurveHintShort, Source={x:Static strings:Strings.Instance}}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Pad_Preset_Label, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <ComboBox AutomationProperties.AutomationId="TriggerPresetCombo"
                                                          Width="120"
                                                          ItemsSource="{x:Static vm:TriggerConfigItem.CurvePresetNames}"
                                                          SelectedItem="{Binding PresetName, Mode=OneWay}"
                                                          SelectionChanged="TriggerPreset_SelectionChanged"
                                                          Tag="{Binding}"/>
                                                <Button Command="{Binding ResetSensitivityCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetSensitivity, Source={x:Static strings:Strings.Instance}}"/>
                                            </StackPanel>

                                            <!-- Live value bar -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Pad_Live, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                                                <ProgressBar Value="{Binding LiveValue, Mode=OneWay}"
                                                             Minimum="0" Maximum="1"
                                                             Width="200" Height="16" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RawDisplay, Mode=OneWay}"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Right: sensitivity curve editor -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="16,-26,0,0">
                                            <TextBlock Text="{Binding Pad_TriggerAxis, Source={x:Static strings:Strings.Instance}}" Margin="0,0,0,4"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="11"/>
                                            <controls:CurveEditor
                                                CurveString="{Binding SensitivityCurve, Mode=TwoWay}"
                                                DeadZone="{Binding DeadZone}"
                                                MaxRange="{Binding MaxRange}"
                                                LiveInput="{Binding LiveInputForCurve}"
                                                IsSigned="False" ChartSize="120"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Margin="0,8,0,12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ─── TAB 5: Force Feedback ─── -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Pad_ForceFeedbackRumble, Source={x:Static strings:Strings.Instance}}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding ResetForceAllCommand}" Style="{StaticResource ResetAllButton}"
                                    Content="{Binding Pad_ResetAll, Source={x:Static strings:Strings.Instance}}" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Overall gain -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Pad_OverallGain, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding ForceOverallGain, Mode=TwoWay}"
                                    Style="{StaticResource DzSlider}"/>
                            <TextBox Text="{Binding ForceOverallGain, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource DzValueEdit}"/>
                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                            <Button Command="{Binding ResetOverallGainCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetOverallGain, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Left motor -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Pad_LeftMotorLabel, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding LeftMotorStrength, Mode=TwoWay}"
                                    Style="{StaticResource DzSlider}"/>
                            <TextBox Text="{Binding LeftMotorStrength, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource DzValueEdit}"/>
                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                            <Button Command="{Binding ResetLeftMotorCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetLeftMotor, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Right motor -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Pad_RightMotorLabel, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding RightMotorStrength, Mode=TwoWay}"
                                    Style="{StaticResource DzSlider}"/>
                            <TextBox Text="{Binding RightMotorStrength, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource DzValueEdit}"/>
                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                            <Button Command="{Binding ResetRightMotorCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetRightMotor, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Swap motors -->
                        <CheckBox Content="{Binding Pad_SwapMotors, Source={x:Static strings:Strings.Instance}}"
                                  IsChecked="{Binding SwapMotors, Mode=TwoWay}"
                                  Margin="0,0,0,12"/>

                        <!-- Test rumble -->
                        <Button Content="{Binding Pad_TestRumble, Source={x:Static strings:Strings.Instance}}"
                                Command="{Binding TestRumbleCommand}"
                                Padding="12,6" HorizontalAlignment="Left"
                                Margin="0,0,0,12"/>

                        <!-- Live motor display -->
                        <TextBlock Text="{Binding Pad_MotorActivity, Source={x:Static strings:Strings.Instance}}" FontWeight="SemiBold" Margin="0,8,0,8"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Pad_LeftMotorLabel, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <ProgressBar Value="{Binding LeftMotorDisplay, Mode=OneWay}"
                                         Minimum="0" Maximum="1"
                                         Width="200" Height="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Pad_RightMotorLabel, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <ProgressBar Value="{Binding RightMotorDisplay, Mode=OneWay}"
                                         Minimum="0" Maximum="1"
                                         Width="200" Height="16" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- ── Audio Bass Rumble ── -->
                        <Separator Margin="0,16,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Settings_AudioRumble, Source={x:Static strings:Strings.Instance}}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding ResetAudioRumbleAllCommand}" Style="{StaticResource ResetAllButton}"
                                    Content="{Binding Pad_ResetAll, Source={x:Static strings:Strings.Instance}}" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Settings_AudioRumbleDesc, Source={x:Static strings:Strings.Instance}}"
                                   Opacity="0.6" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <CheckBox Content="{Binding Settings_AudioRumble_Enable, Source={x:Static strings:Strings.Instance}}"
                                  IsChecked="{Binding AudioRumbleEnabled, Mode=TwoWay}"
                                  Margin="0,0,0,12"/>

                        <!-- Sensitivity -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" IsEnabled="{Binding AudioRumbleEnabled}">
                            <TextBlock Text="{Binding Settings_AudioRumble_Sensitivity, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding AudioRumbleSensitivity, Mode=TwoWay}"
                                    Minimum="1" Maximum="20" Width="200" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AudioRumbleSensitivity, StringFormat='{}{0:F1}'}"
                                       Margin="8,0,0,0" Opacity="0.6" VerticalAlignment="Center"/>
                            <Button Command="{Binding ResetAudioSensitivityCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAudioSensitivity, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Bass Cutoff -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" IsEnabled="{Binding AudioRumbleEnabled}">
                            <TextBlock Text="{Binding Settings_AudioRumble_Cutoff, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding AudioRumbleCutoffHz, Mode=TwoWay}"
                                    Minimum="20" Maximum="200" Width="200" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AudioRumbleCutoffHz, StringFormat='{}{0:F0}'}"
                                       Margin="8,0,0,0" Opacity="0.6" VerticalAlignment="Center"/>
                            <Button Command="{Binding ResetAudioCutoffCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAudioCutoff, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Left Motor -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" IsEnabled="{Binding AudioRumbleEnabled}">
                            <TextBlock Text="{Binding Settings_AudioRumble_LeftMotor, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding AudioRumbleLeftMotor, Mode=TwoWay}"
                                    Style="{StaticResource DzSlider}"/>
                            <TextBox Text="{Binding AudioRumbleLeftMotor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource DzValueEdit}"/>
                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                            <Button Command="{Binding ResetAudioLeftMotorCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAudioLeftMotor, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Right Motor -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" IsEnabled="{Binding AudioRumbleEnabled}">
                            <TextBlock Text="{Binding Settings_AudioRumble_RightMotor, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <Slider Value="{Binding AudioRumbleRightMotor, Mode=TwoWay}"
                                    Style="{StaticResource DzSlider}"/>
                            <TextBox Text="{Binding AudioRumbleRightMotor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource DzValueEdit}"/>
                            <TextBlock Text="%" Style="{StaticResource DzPercent}"/>
                            <Button Command="{Binding ResetAudioRightMotorCommand}" Style="{StaticResource ResetButton}" ToolTip="{Binding Pad_ResetAudioRightMotor, Source={x:Static strings:Strings.Instance}}"/>
                        </StackPanel>

                        <!-- Level meter -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" IsEnabled="{Binding AudioRumbleEnabled}">
                            <TextBlock Text="{Binding Settings_AudioRumble_Level, Source={x:Static strings:Strings.Instance}}" Style="{StaticResource DzLabel}"/>
                            <ProgressBar Value="{Binding AudioRumbleLevelMeter, Mode=OneWay}"
                                         Minimum="0" Maximum="1"
                                         Width="200" Height="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
