<ui:FluentWindow x:Class="PadForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:PadForge"
        xmlns:views="clr-namespace:PadForge.Views"
        xmlns:strings="clr-namespace:PadForge.Resources.Strings"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Title="{Binding Title}"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App branding bar — hamburger on left, PadForge icon + name.
             TitleBar provides native min/max/close with Snap Layout support. -->
        <Grid x:Name="AppBrandingBar" Grid.Row="0" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="PaneToggleBtn" Grid.Column="0" Click="PaneToggleBtn_Click"
                    Width="48" Height="48"
                    Background="Transparent"
                    BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
            </Button>
            <ui:TitleBar x:Name="AppTitleBar" Grid.Column="1"
                         CloseClicked="TitleBar_CloseClicked"
                         MaximizeClicked="TitleBar_MaximizeClicked"
                         ForceShutdown="False">
                <ui:TitleBar.Header>
                    <Border x:Name="AppBrandingBorder" Padding="12,0"
                            Background="Transparent" MouseLeftButtonDown="BrandingBar_MouseDown">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Resources/PadForge-icon.png" Width="20" Height="20"
                                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                            <TextBlock Text="PadForge" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </ui:TitleBar.Header>
                <ui:TitleBar.TrailingContent>
                    <Button x:Name="FullScreenBtn" Click="FullScreenBtn_Click" Width="44" Height="30"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            VerticalAlignment="Top" Margin="0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="LayoutRoot" Property="Background"
                                                            Value="{Binding ButtonsBackground, ElementName=AppTitleBar}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock x:Name="FullScreenIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{Binding ButtonsForeground, ElementName=AppTitleBar}"/>
                    </Button>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>
        </Grid>

        <!-- ═══════════════════════════════════════════
             Navigation View (left pane) with content overlay
             ═══════════════════════════════════════════ -->
        <ui:NavigationView x:Name="NavView" Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           AlwaysShowHeader="False"
                           CompactPaneLength="48"
                           OpenPaneLength="223">

            <ui:NavigationView.Resources>
                <Style TargetType="ui:NavigationViewItem">
                    <Setter Property="Height" Value="48"/>
                    <Setter Property="FontSize" Value="15"/>
                </Style>
            </ui:NavigationView.Resources>

            <!-- MenuItems built programmatically in code-behind (BuildNavigationItems) -->

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItemSeparator/>
                <ui:NavigationViewItem x:Name="NavSettings" Content="{Binding Settings_Title, Source={x:Static strings:Strings.Instance}}" Tag="Settings">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="NavAbout" Content="{Binding About_Title, Source={x:Static strings:Strings.Instance}}" Tag="About">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE946;"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <views:DashboardPage x:Name="DashboardPageView" Visibility="Visible"/>
                    <views:PadPage x:Name="PadPageView" Visibility="Collapsed"/>
                    <views:DevicesPage x:Name="DevicesPageView" Visibility="Collapsed"/>
                    <views:SettingsPage x:Name="SettingsPageView" Visibility="Collapsed"/>
                    <views:ProfilesPage x:Name="ProfilesPageView" Visibility="Collapsed"/>
                    <views:AboutPage x:Name="AboutPageView" Visibility="Collapsed"/>
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>

        <!-- ═══════════════════════════════════════════
             Status Bar
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="{Binding ConnectedDeviceCount, Mode=OneWay}" Opacity="0.7"/>
                    <TextBlock Text="{Binding Main_DevicesSuffix, Source={x:Static strings:Strings.Instance}}" Opacity="0.7"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Opacity="0.7"
                           Text="{Binding PollingFrequency, StringFormat='{}{0:F0} Hz', Mode=OneWay}"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding EngineStatusBrush}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding EngineStatusText}"
                               Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             Driver operation overlay
             ═══════════════════════════════════════════ -->
        <Grid x:Name="DriverOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Panel.ZIndex="1000">
            <Border Background="#80000000"/>
            <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    CornerRadius="8" Padding="32,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="40" Height="40"
                                     Margin="0,0,0,16"/>
                    <TextBlock x:Name="DriverOverlayText"
                               FontSize="16" HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════
             Shutdown overlay
             ═══════════════════════════════════════════ -->
        <Grid x:Name="ShutdownOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Panel.ZIndex="1001">
            <Border Background="#CC000000"/>
            <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    CornerRadius="8" Padding="32,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="40" Height="40"
                                     Margin="0,0,0,16"/>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Text="{Binding Main_ShuttingDown, Source={x:Static strings:Strings.Instance}}"/>
                    <TextBlock x:Name="ShutdownOverlayText"
                               FontSize="13" Opacity="0.7"
                               Margin="0,0,0,4" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
