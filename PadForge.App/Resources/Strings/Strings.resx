  <!-- ═══ About ═══ -->
  <data name="About_Title" xml:space="preserve"><value>About</value></data>
  <data name="About_Subtitle" xml:space="preserve"><value>Controller Mapping Utility</value></data>
  <data name="About_Tagline" xml:space="preserve"><value>Modern fork of x360ce — rebuilt with SDL3, WPF, and .NET 10</value></data>
  <data name="About_Description" xml:space="preserve"><value>PadForge maps any controller, keyboard, or mouse to virtual Xbox 360, DualShock 4, custom DirectInput, or MIDI controllers via ViGEmBus, vJoy, and Windows MIDI Services. It uses SDL3 for controller input, Windows Raw Input for keyboard and mouse input, and provides a modern Fluent Design interface for mapping, dead zone configuration, and force feedback management.</value></data>
  <data name="About_BuiltWith" xml:space="preserve"><value>Built With</value></data>
  <data name="About_DotNet10" xml:space="preserve"><value>.NET 10</value></data>
  <data name="About_DotNet10Desc" xml:space="preserve"><value>Runtime and WPF framework</value></data>
  <data name="About_SDL3" xml:space="preserve"><value>SDL3</value></data>
  <data name="About_SDL3Desc" xml:space="preserve"><value>Controller input and enumeration</value></data>
  <data name="About_RawInput" xml:space="preserve"><value>Raw Input</value></data>
  <data name="About_RawInputDesc" xml:space="preserve"><value>Per-device keyboard and mouse input</value></data>
  <data name="About_ViGEmBus" xml:space="preserve"><value>ViGEmBus</value></data>
  <data name="About_ViGEmBusDesc" xml:space="preserve"><value>Virtual controller driver (Xbox 360, DualShock 4)</value></data>
  <data name="About_VJoy" xml:space="preserve"><value>vJoy</value></data>
  <data name="About_VJoyDesc" xml:space="preserve"><value>Virtual joystick driver for custom DirectInput output</value></data>
  <data name="About_MidiServices" xml:space="preserve"><value>MIDI Services</value></data>
  <data name="About_MidiServicesDesc" xml:space="preserve"><value>Virtual MIDI device output (Windows MIDI Services)</value></data>
  <data name="About_HelixToolkit" xml:space="preserve"><value>HelixToolkit</value></data>
  <data name="About_HelixToolkitDesc" xml:space="preserve"><value>3D controller visualization</value></data>
  <data name="About_ModernWpf" xml:space="preserve"><value>ModernWpf</value></data>
