<Window x:Class="PadForge.Views.ProfileSwitchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!--
        Win11 Hardware Confirmator (volume OSD) — pixel-measured.
        Background: #2C2D2D, Height: 45px, Corner radius: 8px, Gap: 16px above taskbar.
        Outer margin provides space for the subtle shadow without clipping corners.
    -->
    <Grid Margin="16,8,16,16">
        <Border x:Name="FlyoutBorder"
                CornerRadius="8"
                Height="45"
                Padding="16,0,16,0"
                Background="#2C2D2D"
                BorderThickness="0">

            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3"
                                  Direction="270" Opacity="0.25" Color="Black"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="StatusIcon"
                           Text="&#xE8F1;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="White"/>

                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           VerticalAlignment="Center"
                           Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
