<Window x:Class="PadForge.Views.ProfileSwitchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!--
        Win11 Hardware Confirmator (volume/brightness OSD) replica.
        Design tokens from WinUI 3 source + measured from live Win11 24H2:
        - OverlayCornerRadius: 8px
        - AcrylicBackgroundFillColorDefault: TintColor=#2C2C2C, TintOpacity=0.15
        - WPF fallback (no compositor acrylic): #E8202020 (≈91% opaque dark)
        - Height: ~36px (measured from 2560x1600 150% screenshot)
        - Width: content-driven, ~220px for text-only
        - Gap above taskbar: ~6px
        - No visible border stroke
        - Text: Segoe UI Variable Text, 13px
        - Icon: Segoe Fluent Icons, 14px, slightly muted white
    -->
    <Border x:Name="FlyoutBorder"
            CornerRadius="8"
            Height="36"
            Padding="12,0,14,0"
            Background="#E8202020"
            BorderThickness="0">

        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                              Direction="270" Opacity="0.2" Color="Black"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="StatusIcon"
                       Text="&#xE8F1;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#CCFFFFFF"/>

            <TextBlock x:Name="StatusText"
                       FontSize="13"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       VerticalAlignment="Center"
                       Foreground="#EEFFFFFF"/>
        </StackPanel>
    </Border>
</Window>
