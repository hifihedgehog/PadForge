  <data name="About_ViGEmBusDesc" xml:space="preserve"><value>Driver de controle virtual (Xbox 360, DualShock 4)</value></data>
  <data name="About_VJoy" xml:space="preserve"><value>vJoy</value></data>
  <data name="About_VJoyDesc" xml:space="preserve"><value>Driver de joystick virtual para saída DirectInput personalizada</value></data>
  <data name="About_MidiServices" xml:space="preserve"><value>MIDI Services</value></data>
  <data name="About_MidiServicesDesc" xml:space="preserve"><value>Saída de dispositivo MIDI virtual (Windows MIDI Services)</value></data>
